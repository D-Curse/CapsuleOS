FROM python:3.11

RUN apt-get update && apt-get install -y \
    iproute2 \
    iptables \
    util-linux \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY api /app/api
COPY runtime /app/runtime

ENV PYTHONPATH=/app

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]